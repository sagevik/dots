{
    "position": "top",
    "height": 20,
    "modules-left": ["hyprland/workspaces"],
    "modules-right": ["pulseaudio", "cpu", "battery", "memory", "clock" ,"tray"],
    "tray": {
        "spacing": 5
    },
    "clock": {
    	"interval": 1,
    	"timezone": "Europe/Oslo",
    	"format": "ΎΕ│ {:%Y-%m-%d  ΎΑΩ %H:%M}",
    	"tooltip": false,
    },
    "cpu": {
        "format": "ΎΜδ {usage}%",
        "tooltip": false
    },
    "memory": {
        "format": "ΎΦ╕ {}%"
    },
    "battery": {
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-charging": "{icon} {capacity}%",
        "format-plugged": "{icon} {capacity}%",
        "format-alt": "{icon} {time}",
        "format-icons": ["ΎΚΕ", "ΎΚΔ", "ΎΚΓ", "ΎΚΒ", "ΎΚΑ"]
    },
    "network": {
        "format-wifi": "ΎΒχ Wired ΎΘτ",
        "format-ethernet": "ΎΒχ Wired ΎηΨ",
        "format-linked": "{ifname} (No IP) ΎηΨ",
        "format-disconnected": "ΎΒ░ Unwired",
        "format-alt": "{ifname}: {ipaddr}/{cidr}"
    },
    "pulseaudio": {
        "format": "ΎΑρ  {volume}% / {format_source}",
        "format-bluetooth": "ΎΑρ  {volume}%  {format_source}",
        "format-bluetooth-muted": "ΎγσΎΛΦ {format_source}",
        "format-muted": "Ύγσ {format_source}",
        "format-source": "ΎΕ░ {volume}%",
        "format-source-muted": "ΎΕ▒",
        "on-click": "pavucontrol"
    }
}
